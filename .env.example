# Shared
OLLAMA_MODEL=gemma:2b

# API Gateway
API_PORT=8080
MODERATION_SERVICE_URL=http://moderation-service:8081
API_REQUEST_TIMEOUT=120s
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# Moderation Service
MODERATION_PORT=8081
MODERATION_REQUEST_TIMEOUT=90s
LLM_TIMEOUT=60s
CACHE_TTL=10m
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
POSTGRES_DSN=postgres://moderation:moderation@postgres:5432/moderation?sslmode=disable
OLLAMA_BASE_URL=http://ollama:11434

# Audio transcription provider (OpenAI-compatible)
STT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_AUDIO_MODEL=gpt-4o-mini-transcribe

# Gateway CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:8088,http://localhost:8080,https://localhost:443
GATEWAY_DOMAIN=localhost

# Swagger UI settings
SWAGGER_UI_PORT=8088
SWAGGER_SPEC_URL=/openapi.yaml
SWAGGER_SERVER_SCHEME=http
SWAGGER_SERVER_HOST=localhost
SWAGGER_SERVER_PORT=8080

# Optional Kafka
KAFKA_ENABLED=false
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=moderation-events
KAFKA_HEAP_OPTS=-Xms4G -Xmx4G
KAFKA_MEM_LIMIT=6g
KAFKA_MEM_RESERVATION=4g

# Resource profile overrides (tune for your machine)
REDIS_CPUS=0.50
REDIS_MEM_LIMIT=512m
REDIS_MEM_RESERVATION=128m
POSTGRES_CPUS=1.00
POSTGRES_MEM_LIMIT=1g
POSTGRES_MEM_RESERVATION=256m
MODERATION_CPUS=1.00
MODERATION_MEM_LIMIT=1g
MODERATION_MEM_RESERVATION=512m
OLLAMA_CPUS=2.00
OLLAMA_MEM_LIMIT=6g
OLLAMA_MEM_RESERVATION=4g
OLLAMA_INIT_CPUS=0.50
OLLAMA_INIT_MEM_LIMIT=1g
OLLAMA_INIT_MEM_RESERVATION=512m
GATEWAY_CPUS=0.50
GATEWAY_MEM_LIMIT=512m
GATEWAY_MEM_RESERVATION=256m
API_CPUS=0.50
API_MEM_LIMIT=512m
API_MEM_RESERVATION=256m
NGINX_CPUS=0.50
NGINX_MEM_LIMIT=256m
NGINX_MEM_RESERVATION=128m
SWAGGER_CPUS=0.25
SWAGGER_MEM_LIMIT=256m
SWAGGER_MEM_RESERVATION=128m
